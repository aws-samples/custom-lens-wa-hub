                                "displayText": "Use SageMaker deployment guardrails with CloudWatch alarms to auto-rollback unhealthy model deployments.",
                                "url": "https://docs.aws.amazon.com/sagemaker/latest/dg/deployment-guardrails-configuration.html"
                            }
