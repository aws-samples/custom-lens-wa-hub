{
    "schemaVersion": "2021-11-01",
    "name": "AutoGluon on SageMaker AI Best Practice Lens",
    "description": "Best practices for configuring AutoGluon on SageMaker AI",
    "pillars": [
        {
            "id": "PERF",
            "name": "Performance Efficiency",
            "questions": [
                {
                    "id": "PERF1",
                    "title": "Is the model robust across different demand patterns?",
                    "description": "Tests model consistency across different demand patterns",
                    "choices": [
                        {
                            "id": "PERF1_1",
                            "title": "Segment SKUs into demand type with Glue",
                            "helpfulResource": {
                                "displayText": "Classify SKUs into demand types using data pipelines to enable targeted modeling and evaluation",
                                "url": "https://docs.aws.amazon.com/glue/latest/dg/author-job-glue.html"
                            },
                            "improvementPlan": {
                                "displayText": "Use AWS Glue to compute demand features, assign segments, store results for downstream model training pipelines",
                                "url": "https://docs.aws.amazon.com/glue/latest/dg/author-job-glue.html"
                            }
                        },
                        {
                            "id": "PERF1_2",
                            "title": "Evaluate metrics per segment with AutoGluon metrics",
                            "helpfulResource": {
                                "displayText": "Evaluate model performance per segment using AutoGluon metrics, not overall averages",
                                "url": "https://auto.gluon.ai/dev/tutorials/timeseries/forecasting-metrics.html"
                            },
                            "improvementPlan": {
                                "displayText": "Use AutoGluon predictions, compute segment WAPE RMSE, retrain underperforming segments",
                                "url": "https://auto.gluon.ai/dev/tutorials/timeseries/forecasting-metrics.html"
                            }
                        },
                        {
                            "id": "PERF1_3",
                            "title": "Track high-value SKUs separately",
                            "helpfulResource": {
                                "displayText": "Track model performance for high-value SKUs separately using SageMaker Experiments",
                                "url": "https://docs.aws.amazon.com/sagemaker/latest/dg/experiments.html"
                            },
                            "improvementPlan": {
                                "displayText": "Use Amazon SageMaker Experiments to log and monitor metrics for high-value SKU subsets",
                                "url": "https://docs.aws.amazon.com/sagemaker/latest/dg/experiments.html"
                            }
                        }
                    ],
                    "riskRules": [
                        {
                            "condition": "PERF1_1 && PERF1_2 && PERF1_3",
                            "risk": "NO_RISK"
                        },
                        {
                            "condition": "(!PERF1_1) || (!PERF1_2) || (!PERF1_3)",
                            "risk": "HIGH_RISK"
                        },
                        {
                            "condition": "default",
                            "risk": "MEDIUM_RISK"
                        }
                    ]
                },
                {
                    "id": "PERF2",
                    "title": "Is AutoGluon ensemble worth the cost?",
                    "description": "Evaluates ensemble accuracy gain versus training and inference cost",
                    "choices": [
                        {
                            "id": "PERF2_1",
                            "title": "Compare single vs ensemble with leaderboard",
                            "helpfulResource": {
                                "displayText": "Compare Chronos 2 single model against ensemble performance using leaderboard metrics",
                                "url": "https://auto.gluon.ai/stable/api/autogluon.timeseries.TimeSeriesPredictor.leaderboard.html"
                            },
                            "improvementPlan": {
                                "displayText": "Use AutoGluon leaderboard to compare accuracy and cost, choose best trade-off model",
                                "url": "https://auto.gluon.ai/stable/api/autogluon.timeseries.TimeSeriesPredictor.leaderboard.html"
                            }
                        },
                        {
                            "id": "PERF2_2",
                            "title": "Measure training &amp; inference cost with leaderboard",
                            "helpfulResource": {
                                "displayText": "Evaluate training and inference costs to understand resource usage and efficiency",
                                "url": "https://docs.aws.amazon.com/sagemaker/latest/dg/monitoring-cloudwatch.html"
                            },
                            "improvementPlan": {
                                "displayText": "Use Amazon SageMaker metrics and CloudWatch to monitor, optimize, and reduce costs",
                                "url": "https://docs.aws.amazon.com/sagemaker/latest/dg/monitoring-cloudwatch.html"
                            }
                        },
                        {
                            "id": "PERF2_3",
                            "title": "Apply ensemble selectively",
                            "helpfulResource": {
                                "displayText": "Use ensemble models only where they significantly improve accuracy",
                                "url": "https://docs.aws.amazon.com/sagemaker/latest/dg/build-and-manage-steps.html"
                            },
                            "improvementPlan": {
                                "displayText": "Use AutoGluon leaderboard to apply ensembles only to high-value or complex segments",
                                "url": "https://docs.aws.amazon.com/sagemaker/latest/dg/build-and-manage-steps.html"
                            }
                        }
                    ],
                    "riskRules": [
                        {
                            "condition": "PERF2_1 && PERF2_2 && PERF2_3",
                            "risk": "NO_RISK"
                        },
                        {
                            "condition": "(!PERF2_1)",
                            "risk": "HIGH_RISK"
                        },
                        {
                            "condition": "default",
                            "risk": "MEDIUM_RISK"
                        }
                    ]
                },
                {
                    "id": "PERF3",
                    "title": "Can the model capture promotions and spikes?",
                    "description": "Assesses ability to model promotions and demand spikes",
                    "choices": [
                        {
                            "id": "PERF3_1",
                            "title": "Add promotion/event features",
                            "helpfulResource": {
                                "displayText": "Incorporate promotion and event signals as time-varying covariates for forecasting",
                                "url": "https://auto.gluon.ai/stable/tutorials/timeseries/forecasting-indepth.html"
                            },
                            "improvementPlan": {
                                "displayText": "Use AutoGluon known covariates to pass aligned event features into models",
                                "url": "https://auto.gluon.ai/stable/tutorials/timeseries/forecasting-indepth.html"
                            }
                        },
                        {
                            "id": "PERF3_2",
                            "title": "Create lagged promotion features with Glue ETL",
                            "helpfulResource": {
                                "displayText": "Generate lagged promotion features to capture delayed effects of promotions on demand",
                                "url": "https://docs.aws.amazon.com/glue/latest/dg/author-job-glue.html"
                            },
                            "improvementPlan": {
                                "displayText": "Use AWS Glue ETL jobs to create lag features and join with time-series data",
                                "url": "https://docs.aws.amazon.com/glue/latest/dg/author-job-glue.html"
                            }
                        },
                        {
                            "id": "PERF3_3",
                            "title": "Evaluate promotion-period error with StepFunction",
                            "helpfulResource": {
                                "displayText": "Evaluate model accuracy specifically during promotion periods using orchestrated workflow steps",
                                "url": "https://docs.aws.amazon.com/step-functions/latest/dg/workflow-studio.html"
                            },
                            "improvementPlan": {
                                "displayText": "Use AWS Step Functions to orchestrate evaluation tasks and compute promotion-period metrics automatically",
                                "url": "https://docs.aws.amazon.com/step-functions/latest/dg/workflow-studio.html"
                            }
                        }
                    ],
                    "riskRules": [
                        {
                            "condition": "PERF3_1 && PERF3_2 && PERF3_3",
                            "risk": "NO_RISK"
                        },
                        {
                            "condition": "(!PERF3_1) || (!PERF3_3)",
                            "risk": "HIGH_RISK"
                        },
                        {
                            "condition": "default",
                            "risk": "MEDIUM_RISK"
                        }
                    ]
                },
                {
                    "id": "PERF4",
                    "title": "Is forecast horizon aligned?",
                    "description": "Forecast horizon matches business decision timeframes",
                    "choices": [
                        {
                            "id": "PERF4_1",
                            "title": "Evaluate multiple horizons with prediction length",
                            "helpfulResource": {
                                "displayText": "Evaluate model performance across different forecast horizons using varying prediction lengths",
                                "url": "https://auto.gluon.ai/stable/tutorials/timeseries/forecasting-indepth.html"
                            },
                            "improvementPlan": {
                                "displayText": "Use AutoGluon prediction_length to train and compare horizon-specific model accuracy",
                                "url": "https://auto.gluon.ai/stable/tutorials/timeseries/forecasting-indepth.html"
                            }
                        },
                        {
                            "id": "PERF4_2",
                            "title": "Use horizon-specific features",
                            "helpfulResource": {
                                "displayText": "Use different feature sets for different forecast horizons",
                                "url": "https://auto.gluon.ai/stable/tutorials/timeseries/forecasting-indepth.html"
                            },
                            "improvementPlan": {
                                "displayText": "Use AutoGluon prediction_length with horizon-specific covariates for separate short- and long-term models.",
                                "url": "https://auto.gluon.ai/stable/tutorials/timeseries/forecasting-indepth.html"
                            }
                        }
                    ],
                    "riskRules": [
                        {
                            "condition": "PERF4_1 && PERF4_2",
                            "risk": "NO_RISK"
                        },
                        {
                            "condition": "(!PERF4_1)",
                            "risk": "HIGH_RISK"
                        },
                        {
                            "condition": "default",
                            "risk": "MEDIUM_RISK"
                        }
                    ]
                },
                {
                    "id": "PERF5",
                    "title": "Are long-tail SKUs under-modeled?",
                    "description": "Checks if low-volume SKUs are poorly predicted",
                    "choices": [
                        {
                            "id": "PERF5_1",
                            "title": "Evaluate low-volume SKUs",
                            "helpfulResource": {
                                "displayText": "Evaluate model performance specifically for low-volume or long-tail SKUs",
                                "url": "https://auto.gluon.ai/stable/tutorials/timeseries/forecasting-indepth.html"
                            },
                            "improvementPlan": {
                                "displayText": "Use AutoGluon predictions to compute metrics for low-volume SKUs and retrain models",
                                "url": "https://auto.gluon.ai/stable/tutorials/timeseries/forecasting-indepth.html"
                            }
                        },
                        {
                            "id": "PERF5_2",
                            "title": "Use group-level and mapping to SKU-level",
                            "helpfulResource": {
                                "displayText": "Use group-level forecasts when SKU-level predictions are unreliable",
                                "url": "https://auto.gluon.ai/stable/tutorials/timeseries/forecasting-indepth.html"
                            },
                            "improvementPlan": {
                                "displayText": "Train category-level models in AutoGluon and  mapping to SKU-level",
                                "url": "https://auto.gluon.ai/stable/tutorials/timeseries/forecasting-indepth.html"
                            }
                        }
                    ],
                    "riskRules": [
                        {
                            "condition": "PERF5_1 && PERF5_2",
                            "risk": "NO_RISK"
                        },
                        {
                            "condition": "(!PERF5_2)",
                            "risk": "HIGH_RISK"
                        },
                        {
                            "condition": "default",
                            "risk": "MEDIUM_RISK"
                        }
                    ]
                }
            ]
        },
        {
