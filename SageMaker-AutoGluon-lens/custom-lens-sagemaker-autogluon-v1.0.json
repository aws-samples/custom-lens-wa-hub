                                "displayText": "Ensure input data is fresh, complete, and accurate before model training",
                                "url": "https://docs.aws.amazon.com/glue/latest/dg/glue-data-quality.html"
                            },
                            "improvementPlan": {
                                "displayText": "Use AWS Glue Data Quality rules to validate freshness, completeness, and trigger alerts",
                                "url": "https://docs.aws.amazon.com/glue/latest/dg/glue-data-quality.html"
                            }
                        }
