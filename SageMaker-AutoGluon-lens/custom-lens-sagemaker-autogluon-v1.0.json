                            "condition": "(!OPS1_1) || (!OPS1_2)",
                            "risk": "HIGH_RISK"
                        },
                        {
                            "condition": "default",
                            "risk": "MEDIUM_RISK"
                        }
                    ]
                },
                {
                    "id": "OPS2",
                    "title": "How do you design your MLOps process to support your model training and inference?",
                    "description": "Ensures automated retraining, data validation, performance tracking, and safe model promotion or rollback",
                    "choices": [
                        {
                            "id": "OPS2_1",
                            "title": "Build end-to-end pipeline with StepFunction",
                            "helpfulResource": {
                                "displayText": "Orchestrate end-to-end ML workflow from data processing to deployment using workflow automation",
                                "url": "https://docs.aws.amazon.com/step-functions/latest/dg/workflow-studio.html"
                            },
                            "improvementPlan": {
                                "displayText": "Use AWS Step Functions to orchestrate ETL training evaluation and deployment steps reliably",
                                "url": "https://docs.aws.amazon.com/step-functions/latest/dg/workflow-studio.html"
                            }
                        },
                        {
                            "id": "OPS2_2",
                            "title": "Schedule retraining with EventBridge",
                            "helpfulResource": {
                                "displayText": "Automate model retraining on a defined schedule based on time or events",
                                "url": "https://docs.aws.amazon.com/eventbridge/latest/userguide/using-eventbridge-scheduler.html"
                            },
                            "improvementPlan": {
                                "displayText": "Use Amazon EventBridge to trigger retraining pipelines on schedules or data-driven events",
                                "url": "https://docs.aws.amazon.com/eventbridge/latest/userguide/using-eventbridge-scheduler.html"
                            }
                        },
                        {
                            "id": "OPS2_3",
                            "title": "Fallback to previous model with sagemaker deployment",
